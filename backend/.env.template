# ============================================================
# Signal CRM — Backend Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Supabase Database ─────────────────────────────────────────
# Direct connection (session mode, port 5432) — use for Gunicorn workers
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase project keys (for Supabase client SDK if needed)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── JWT Auth ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_ALGORITHM=HS256

# ── CORS Origins ──────────────────────────────────────────────
# Comma-separated list of extra allowed origins (beyond defaults)
EXTRA_CORS_ORIGINS=

# ── AI APIs ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Payments (Razorpay) ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Bank Details (SWIFT / NEFT payments) ─────────────────────
BANK_NAME=Axis Bank Ltd
BANK_ACCOUNT_NUMBER=922020067340454
BANK_ACCOUNT_HOLDER=Nanoneuron Services
BANK_IFSC=UTIB0005124
SWIFT_CODE=AXISINBB
BANK_SWIFT_ADDRESS=Axis Bank Ltd, Tilekar Road Branch, Pune, Maharashtra, India
UPI_ID=
BANK_USD_ACCOUNT=
BANK_EUR_ACCOUNT=

# ── Email / SMTP ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=signal@nanoneuron.ai
FROM_NAME=Signal CRM
